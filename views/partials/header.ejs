<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Shri Saileela Palkhi Sohala 2026' %></title>
  
  <!-- Fonts & Icons -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  
  <!-- Core Formal Styling -->
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <!-- Top Announcement Header Bar -->
  <div class="top-announcement">
    <div class="container announcement-flex">
      <div class="announcement-text">
        <span class="announcement-badge">LIVE YATRA</span>
        <span>🚩 Shri Saileela Palkhi Sohala 2026 is currently at <strong>Talegaon Dabhade Halt</strong>. Next stop: Rajgurunagar Ashram.</span>
      </div>
      <div class="top-contacts">
        <span><i class="bi bi-telephone-fill">Control Room:</i> +91 98765 43210</span>
        <span><i class="bi bi-geo-alt-fill">Emergency Desk:</i> Shirdi Highway Camp</span>
      </div>
    </div>
  </div>

  <!-- Main Site Header -->
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="brand-logo">
        <div class="brand-icon">
          <i class="bi bi-flower1"></i>
        </div>
        <div class="brand-text">
          <h1>SAILEELA PALKHI</h1>
          <p>Shri Sai Leela Seva Trust (Reg. E-3892)</p>
        </div>
      </a>

      <!-- Navigation Links -->
      <nav class="main-nav" id="mainNav">
        <ul>
          <li><a href="/" class="nav-link <%= activeTab === 'home' ? 'active' : '' %>"><i class="bi bi-house-door"></i> Home</a></li>
          <li><a href="/schedule" class="nav-link <%= activeTab === 'schedule' ? 'active' : '' %>"><i class="bi bi-map"></i> Route Schedule</a></li>
          <li><a href="/register-pass" class="nav-link <%= activeTab === 'register' ? 'active' : '' %>"><i class="bi bi-person-badge"></i> Get Devotee Pass</a></li>
          <li><a href="/pass-status" class="nav-link <%= activeTab === 'pass-status' ? 'active' : '' %>"><i class="bi bi-qr-code-scan"></i> Verify Pass</a></li>
          <li><a href="/donate" class="nav-link <%= activeTab === 'donate' ? 'active' : '' %>"><i class="bi bi-heart-fill" style="color: var(--primary-gold);"></i> Seva Donation</a></li>
          <li><a href="/admin" class="nav-link nav-btn <%= activeTab === 'admin' ? 'active' : '' %>"><i class="bi bi-speedometer2"></i> Admin Panel</a></li>
          <li>
            <button id="themeToggle" class="theme-toggle-btn" title="Toggle Dark/Light Mode" aria-label="Toggle Theme">
              <i class="bi bi-moon-stars-fill"></i>
            </button>
          </li>
        </ul>
      </nav>

      <button class="mobile-toggle" id="mobileToggle" aria-label="Toggle navigation menu">
        <i class="bi bi-list"></i>
      </button>
    </div>
  </header>
